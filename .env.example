# -----------------------------------------------------------------------------
# Local setup:
# 1) Copy this file to .env.local
# 2) Run: docker compose up -d
# 3) Run: npm install
# 4) Run: npm run db:migrate && npm run db:seed
# 5) Run: npm run dev
# Never commit real secrets. Use placeholder values only in this template.
# -----------------------------------------------------------------------------

# Core application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/therapy_clinic_dev
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_optional

# Authentication (NextAuth/Auth.js compatibility)
AUTH_SECRET=your_auth_secret
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_legacy
NEXTAUTH_URL=http://localhost:3000
AUTH_PROVIDERS=credentials,keycloak
DEV_BYPASS_AUTH=false

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=therapy-clinic
KEYCLOAK_CLIENT_ID=therapy-clinic-app
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret

# Security and observability
ARCJET_KEY=ajkey_your_arcjet_key
SENTRY_DSN=your_sentry_dsn
SENTRY_ORGANIZATION=your_sentry_organization
SENTRY_PROJECT=your_sentry_project
SENTRY_AUTH_TOKEN=your_sentry_auth_token
NEXT_PUBLIC_SENTRY_DISABLED=true
NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=your_better_stack_source_token
NEXT_PUBLIC_BETTER_STACK_INGESTING_HOST=your_better_stack_ingesting_host

# PHI encryption
PHI_ENCRYPTION_KEY=your_64_char_hex_phi_encryption_key
PHI_ENCRYPTION_KEY_ID=your_phi_encryption_key_id
AWS_REGION=your_aws_region
AWS_KMS_KEY_ID=your_aws_kms_key_id

# Notifications
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=notifications@example.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+10000000000

# Product analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Build tooling
NEXT_TELEMETRY_DISABLED=1
