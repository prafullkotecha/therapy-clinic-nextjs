# Production environment template
# Copy this file to `.env.production.local` and fill in real secret values there.
# Do not commit secrets to source control.

# Public application URL
NEXT_PUBLIC_APP_URL=https://your-production-domain.example.com

# Error monitoring
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORGANIZATION=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Checkly
# CHECKLY_EMAIL_ADDRESS=
# CHECKLY_PROJECT_NAME=therapy-clinic-nextjs
# CHECKLY_LOGICAL_ID=therapy-clinic-nextjs
